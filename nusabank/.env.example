# ─────────────────────────────────────────────────────────────
# NusaBank — Environment Variables
# ─────────────────────────────────────────────────────────────
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# cp .env.example .env

# DATABASE (PostgreSQL — gunakan Vercel Postgres / Neon / Supabase)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/nusabank?sslmode=require

# SECRET KEY — ganti dengan string acak yang panjang dan unik
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-aman

# FLASK ENVIRONMENT
FLASK_ENV=development
